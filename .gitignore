# Build output
**/bin/
**/obj/

# Node / UI
ui/node_modules/
ui/dist/

# IDE
.vs/
*.user
*.suo

# OS
Thumbs.db
Desktop.ini
.DS_Store

# Secrets — never commit
appsettings.json
!appsettings.example.json
.env

# Claude Code per-user/per-machine settings (permission allowlist; may contain
# API keys baked into Bash/PowerShell command patterns). Project-shared rules
# belong in .claude/settings.json which IS committed.
.claude/settings.local.json

# Claude Code worktrees — each EnterWorktree creates an isolated checkout here.
# These are independent working trees of this same repo; never commit them as
# untracked files into a parent branch.
.claude/worktrees/

# Deployment output
publish/
**/wwwroot/

# SQLite databases
*.db
*.db-shm
*.db-wal
# Ignore everything in data/ except version-controlled SQL data packs (see docs/data-packs.md).
data/*
!data/datapacks/

# Docker config (contains secrets — same structure as appsettings.json)
docker-config/

# Docker auth state (Playwright SSO sessions — refreshed via refresh-auth-state.ps1)
docker-auth-state/

# Docker backup target (scheduled SQLite snapshots — bind-mounted into the container)
docker-backups/

# Media Foundation DLLs copied from the host for the Windows container build
docker-mf-dlls/

# Logs & runtime data
logs/
screenshots/
*.log

# aseXML generation output (rendered payloads — reproducible from test sets)
output/

# Auth state
*-auth-state.json

# Playwright browsers
playwright/
