# Build output
**/bin/
**/obj/

# Node / UI
ui/node_modules/
ui/dist/

# IDE
.vs/
*.user
*.suo

# OS
Thumbs.db
Desktop.ini
.DS_Store

# Secrets — never commit
appsettings.json
!appsettings.example.json
.env

# Deployment output
publish/
**/wwwroot/

# SQLite databases
*.db
*.db-shm
*.db-wal
data/

# Docker config (contains secrets — same structure as appsettings.json)
docker-config/

# Docker auth state (Playwright SSO sessions — refreshed via refresh-auth-state.ps1)
docker-auth-state/

# Media Foundation DLLs copied from the host for the Windows container build
docker-mf-dlls/

# Logs & runtime data
logs/
screenshots/
*.log

# aseXML generation output (rendered payloads — reproducible from test sets)
output/

# Auth state
*-auth-state.json

# Playwright browsers
playwright/
