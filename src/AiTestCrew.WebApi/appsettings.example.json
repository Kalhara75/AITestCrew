{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "TestEnvironment": {
    "LlmProvider":    "Anthropic",
    "LlmApiKey":      "<your-claude-api-key>",
    "LlmModel":       "claude-sonnet-4-6",
    "// LlmMode": "Auto (default) = use local key if present, else proxy when ServerUrl+ApiKey set. Local = always local. RemoteProxy = always proxy.",
    "LlmMode":        "Auto",

    "ListenUrl": "",
    "CorsOrigins": [],

    "StorageProvider": "File",
    "SqliteConnectionString": "",

    "OpenApiSpecUrl": null,

    "DefaultApiStack":  null,
    "DefaultApiModule": null,
    "ApiStacks": {
      "bravecloud": {
        "BaseUrl": "https://sumo-dev.braveenergy.com.au",
        "SecurityModule": "security",
        "LoginPath": "/AccessManagement/Login",
        "Modules": {
          "sdr":      { "Name": "SDR (BraveCloud)",      "PathPrefix": "sdrbc/api/v1" },
          "security": { "Name": "Security (BraveCloud)",  "PathPrefix": "sec/api/v1" },
          "mds":      { "Name": "MDS (BraveCloud)",       "PathPrefix": "mdsbc/api/v1" }
        }
      },
      "legacy": {
        "BaseUrl": "https://api-sumodev.braveenergy.com.au",
        "SecurityModule": "security",
        "LoginPath": "/AccessManagement/Login",
        "Modules": {
          "sdr":      { "Name": "SDR (Legacy)",      "PathPrefix": "sdrapi/api/v1" },
          "security": { "Name": "Security (Legacy)",  "PathPrefix": "secapi/api/v1" },
          "eb2b":     { "Name": "EB2B (Legacy)",       "PathPrefix": "eb2bapi/api/v1" }
        }
      }
    },

    "AuthToken":      "<your-bearer-token-or-leave-empty-for-auto-login>",
    "AuthScheme":     "Bearer",
    "AuthHeaderName": "Authorization",
    "AuthUsername":    null,
    "AuthPassword":   null,

    "// Auth recovery": "Seamless authentication: silent retry on 401, mid-test login-redirect detection, pause/resume orchestration. AutoRecoverApi/AutoRecoverUi=true (default) handle the common case (rotated JWT, expired cookie) silently. PauseOnAuthFailure=true (default) parks runs in AwaitingAuth pending an auth-refresh; set false to fail fast in headless CI.",
    "Auth": {
      "AutoRecoverApi": true,
      "AutoRecoverUi": true,
      "LoginRedirectUrlPatterns": ["login.microsoftonline.com", "/Account/Login"],
      "AuthRefreshMaxLatencySeconds": 300,
      "PauseOnAuthFailure": true,
      "ExpiryWarningHours": 1
    },

    "MaxParallelAgents":     4,
    "DefaultTimeoutSeconds": 300,
    "VerboseLogging":        false,
    "MaxExecutionRunsPerTestSet": 10,

    "PlaywrightBrowser":  "chromium",
    "PlaywrightHeadless": true,
    "PlaywrightScreenshotDir": "screenshots",

    "LegacyWebUiUrl":      "https://your-legacy-app.example.com",
    "LegacyWebUiLoginPath": "/Account/Login",
    "LegacyWebUiUsername": "<legacy-username>",
    "LegacyWebUiPassword": "<legacy-password>",
    "LegacyWebUiStorageStatePath":       "legacy-auth-state.json",
    "LegacyWebUiStorageStateMaxAgeHours": 8,

    "BraveCloudUiUrl":                   "https://your-bravecloud-app.example.com",
    "BraveCloudUiStorageStatePath":       "bravecloud-auth-state.json",
    "BraveCloudUiUsername":               "<aad-email@yourdomain.com>",
    "BraveCloudUiPassword":               "<aad-password>",
    "BraveCloudUiStorageStateMaxAgeHours": 8,
    "BraveCloudUiTotpSecret":             "",

    "WinFormsAppPath":                    "",
    "WinFormsAppArgs":                    null,
    "WinFormsAppLaunchTimeoutSeconds":    30,
    "WinFormsScreenshotDir":              "screenshots",

    "// Data packs": "Version-controlled SQL scripts under data/datapacks/{phase}/{envKey}/{NN.subfolder}/{NN.script}.sql, packaged into bin/datapacks/ and run by the WebApi at startup. DESTRUCTIVE — opt-in is per-env only via Environments.<env>.RunDataPacksOnStartup. DataPacksPath is the bin-relative root.",
    "DataPacksPath": "datapacks",
    "TeardownExecAllowedPrefixes": ["usp_"],

    "// Jira Xray integration": "Xray import (POST /api/xray/import). Server-side only — agent boxes and the Runner never see these credentials; they call /api/xray/* over HTTP. Mode: Cloud (Xray Cloud JWT) or Server (Server/DC Basic auth). Leave BaseUrl empty to disable the integration.",
    "JiraXray": {
      "Mode": "Cloud",
      "BaseUrl": "https://yourtenant.atlassian.net",
      "XrayClientId": "<xray-client-id-from-api-keys-page>",
      "XrayClientSecret": "<xray-client-secret>",
      "JiraEmail": "<your-jira-email>",
      "JiraApiToken": "<jira-api-token-from-account-settings>"
    },

    "DefaultEnvironment": "sumo-retail",
    "Environments": {
      "sumo-retail": {
        "DisplayName": "Sumo Retail",
        "BraveCloudUiUrl": "https://sumo-dev.braveenergy.com.au",
        "BraveCloudUiStorageStatePath": "bravecloud-auth-state.sumo.json",
        "LegacyWebUiStorageStatePath": "legacy-auth-state.sumo.json",
        "DataTeardownEnabled": false,
        "RunDataPacksOnStartup": false,
        "AuthHealthEnabled": true,
        "ApiStackBaseUrls": {
          "bravecloud": "https://sumo-dev.braveenergy.com.au",
          "legacy":     "https://api-sumodev.braveenergy.com.au"
        }
      },
      "ams-metering": {
        "DisplayName": "AMS Metering",
        "BraveCloudUiUrl": "https://ams-dev.braveenergy.com.au",
        "BraveCloudUiStorageStatePath": "bravecloud-auth-state.ams.json",
        "LegacyWebUiStorageStatePath": "legacy-auth-state.ams.json",
        "DataTeardownEnabled": false,
        "RunDataPacksOnStartup": false,
        "AuthHealthEnabled": false,
        "ApiStackBaseUrls": {
          "bravecloud": "https://ams-dev.braveenergy.com.au",
          "legacy":     "https://api-amsdev.braveenergy.com.au"
        }
      }
    }
  }
}
