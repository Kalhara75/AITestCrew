# AITestCrew — Environment Variables
# Copy this file to .env and fill in the values.
# These override the corresponding TestEnvironment.* settings in appsettings.json.
#
# Variable naming: AITESTCREW_TestEnvironment__<PropertyName>
# Nested objects use double underscores: AITESTCREW_TestEnvironment__AseXml__BravoDb__ConnectionString

# ── LLM (required) ──
AITESTCREW_TestEnvironment__LlmProvider=Anthropic
AITESTCREW_TestEnvironment__LlmApiKey=sk-ant-...
AITESTCREW_TestEnvironment__LlmModel=claude-sonnet-4-6

# ── Server ──
# AITESTCREW_TestEnvironment__ListenUrl=http://+:5050
# AITESTCREW_TestEnvironment__CorsOrigins__0=https://qa-dashboard.company.com

# ── Storage ──
# AITESTCREW_TestEnvironment__StorageProvider=Sqlite
# AITESTCREW_TestEnvironment__SqliteConnectionString=Data Source=C:/data/aitestcrew.db

# ── API targets (optional) ──
# AITESTCREW_TestEnvironment__AuthUsername=
# AITESTCREW_TestEnvironment__AuthPassword=

# ── aseXML Bravo DB (optional, for --list-endpoints / delivery) ──
# AITESTCREW_TestEnvironment__AseXml__BravoDb__ConnectionString=Server=...;Database=...;
